PORT=3000
JWT_SECRET=change_this_to_a_random_long_string

# Stripe (https://dashboard.stripe.com/apikeys)
# Leave empty to use demo mode (no real payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Your public URL — used for Stripe redirects and server logs.
# Set this to your Cloudflare tunnel domain in production.
APP_URL=https://learn.speedek.org

# Ollama (local AI server) — install from https://ollama.ai
# Leave defaults if Ollama runs on the same machine as this server.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
